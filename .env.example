# Family Calendar - Environment Configuration
# Copy this file to .env and configure for your deployment

# ============================================================================
# Database Configuration (Phase 1: Dual-Write Mode)
# ============================================================================

# Enable database integration (default: false for backward compatibility)
# Set to 'true' to enable Phase 1 dual-write mode (files primary, database secondary)
FAMCAL_USE_DATABASE=true

# Enable database-first ICS generation (Phase 3, default: true when database enabled)
# Set to 'false' to serve ICS from files instead of database
FAMCAL_DATABASE_ICS=true

# Database connection URL
# PostgreSQL (Production): postgresql://username:password@hostname:port/database
# SQLite (Development): sqlite:///famcal.db
# SQLite (In-Memory): sqlite:///:memory:
SQLALCHEMY_DATABASE_URL=postgresql://famcal_user:YOUR_SECURE_PASSWORD@localhost:5432/famcal_db

# ============================================================================
# Application Configuration
# ============================================================================

# Path to configuration file (default: family_config.json)
FAMILY_CONFIG=family_config.json

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Production Notes
# ============================================================================
# 
# For systemd service: Add Environment directives in famcal.service
# For gunicorn/WSGI: Load environment variables before starting
# For PythonAnywhere: Set in Web tab > Environment Variables
# 
# **Phase 3 (Current): Database-first ICS generation**
# - ICS feeds served from database (primary)
# - Events synced to files as backup
# - Falls back to files if database unavailable
# - Database is the source of truth
# 
# To disable database ICS: Set FAMCAL_DATABASE_ICS=false
# System will continue syncing to database but serve ICS from files
# 
# Future Phase 4: Remove file dependency entirely (database-only)
